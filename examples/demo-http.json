{
  "version": "2.1.0",
  "manifest": {
    "bundle_id": "demo-http-get",
    "created_at": "2025-01-01T00:00:00Z",
    "description": "Demo HTTP GET request replay",
    "tags": ["demo", "http", "get"],
    "author": "SentinelOps-CI",
    "expected_duration_ms": 5000
  },
  "replay_data": {
    "type": "http",
    "payload": {
      "method": "GET",
      "url": "https://httpbin.org/get",
      "headers": {
        "User-Agent": "Morph-Replay-Runner/0.1.0"
      },
      "timeout": 10
    },
    "preconditions": [
      {
        "type": "network",
        "condition": "Internet connectivity available",
        "timeout_ms": 5000
      }
    ],
    "postconditions": [
      {
        "type": "response",
        "condition": "HTTP 200 response received",
        "expected_result": "success"
      }
    ]
  },
  "dependencies": [
    {
      "name": "curl",
      "version": "7.0+",
      "type": "package"
    }
  ],
  "execution_config": {
    "timeout_ms": 10000,
    "retry_count": 2,
    "environment": {
      "CURL_TIMEOUT": "10"
    },
    "working_directory": "/tmp"
  }
}
